# CoffeeMaster Backend - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/coffeemaster

# JWT — use a long, random secret in production (at least 64 chars)
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Frontend URL (used for CORS + Socket.io)
FRONTEND_URL=http://localhost:3000

# Optional: set to your deployed domain in production
# FRONTEND_URL=https://yourdomain.com
